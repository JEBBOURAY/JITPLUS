# Configuration de l'API Backend
# Remplacer par l'URL appropriée selon votre environnement

# Développement local (émulateur Android)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Développement local (iOS / simulateur)
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Appareil physique (remplacer 192.168.1.X par l'IP de votre machine)
# Pour trouver votre IP:
#   Windows: ipconfig
#   Mac/Linux: ifconfig
EXPO_PUBLIC_API_URL=http://192.168.1.X:3000

# Production
# EXPO_PUBLIC_API_URL=https://api.jitplus.com

# -- Google Maps ---------------------------------------------
# API key for Google Maps SDK (Android & iOS)
# Get it from Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_RENDERER=LATEST

# -- Google OAuth (expo-auth-session browser flow → Web client ID on all platforms)
# Web client ID from Google Cloud Console → Credentials → OAuth 2.0 (type Web)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android client ID (type Android, SHA-1 keyed) — used for reference / eas.json
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS client ID (optional — falls back to Web client ID for expo-auth-session)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# -- Force-update --------------------------------------------
# Apple App Store numeric ID (found in App Store Connect)
EXPO_PUBLIC_IOS_APP_ID=

