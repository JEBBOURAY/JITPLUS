# ── Développement local ───────────────────────────────────────────
# Format TCP (docker-compose ou postgres local)
DATABASE_URL="postgresql://admin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/jit_db?schema=public"
# Format Cloud SQL unix socket (Cloud Run) :
# DATABASE_URL="postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE"

JWT_SECRET="CHANGE_ME_USE_openssl_rand_-base64_64_to_generate"
JWT_EXPIRATION="1h"

# Separate HMAC key for QR tokens (recommended — falls back to JWT_SECRET if empty)
QR_HMAC_SECRET="CHANGE_ME_USE_openssl_rand_-base64_32_to_generate"

PORT=3000

# Sentry — error monitoring (laisser vide pour désactiver)
SENTRY_DSN=""

# Cache — en mémoire (in-process). Suffisant pour une seule instance Cloud Run.
# Pour un déploiement multi-instances, envisager un cache externe (ex : Memorystore).

# CORS origins (CSV) — requis en production
# Exemple: https://jitplus.ma,https://admin.jitplus.ma
CORS_ORIGINS=""

# Resend API key — emails transactionnels (REQUIS en production)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# URL publique du backend — utilisée pour les images dans les push notifications
# En production : URL Cloud Run (ex: https://jitplus-api-xxx-ew.a.run.app)
BACKEND_URL="http://localhost:3000"

# ── Firebase Admin SDK — Push Notifications (REQUIS en production) ────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── SMTP — Gmail (utiliser un "Mot de passe d'application" Google) ─────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="contact@jitplus.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="JitPlus <contact@jitplus.com>"

# ── Twilio — OTP SMS via WhatsApp ────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Content Template SID (requis en prod, ignoré en sandbox)
TWILIO_OTP_CONTENT_SID="HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Marketing Template SID — requis pour envoyer des promos WhatsApp hors session 24h
# Créer dans Twilio Console → Content → Content Templates (catégorie MARKETING)
TWILIO_MARKETING_CONTENT_SID="HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Google Cloud Platform ─────────────────────────────────────
# REQUIS en production — pas nécessaire en local si on ne teste pas l'upload
GCP_PROJECT_ID="jitplus-97259"
GCP_STORAGE_BUCKET_NAME="jitplus-uploads-prod"

# Nom de l'instance Cloud SQL (utilisé dans cloudbuild.yaml pour le flag --add-cloudsql-instances)
# Format : PROJECT:REGION:INSTANCE
CLOUD_SQL_INSTANCE="jitplus-97259:europe-west9:jitplus-db"

# En développement local seulement : chemin vers le JSON de compte de service
# Sur Cloud Run, l'auth est automatique via le compte de service attaché — ne pas définir.
# GOOGLE_APPLICATION_CREDENTIALS="./jitplus-97259-key.json"

# ── Google OAuth (connexion client) ───────────────────────────
GOOGLE_CLIENT_ID=""

# -- Force-update / Maintenance ----------------------------
MIN_IOS_VERSION=1.0.0
MIN_ANDROID_VERSION=1.0.0
MAINTENANCE_MODE=false

