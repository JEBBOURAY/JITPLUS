// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Merchant {
  id                   String           @id @default(uuid())
  nom                  String           @db.VarChar(255)
  email                String           @unique @db.VarChar(255)
  password             String           @db.VarChar(255)
  googleId             String?          @unique @map("google_id") @db.VarChar(255)
  appleId              String?          @unique @map("apple_id") @db.VarChar(255)
  pushToken            String?          @map("push_token") @db.VarChar(512)
  termsAccepted        Boolean          @default(false) @map("terms_accepted")
  categorie            MerchantCategory
  description          String?          @db.VarChar(1000)
  ville                String?          @db.VarChar(100)
  quartier             String?          @db.VarChar(100)
  adresse              String?          @db.VarChar(500)
  latitude             Float?
  longitude            Float?
  countryCode          String           @default("MA") @map("country_code") @db.VarChar(5)
  phoneNumber          String?          @map("phone_number") @db.VarChar(20)
  logoUrl              String?          @map("logo_url")
  coverUrl             String?          @map("cover_url")
  socialLinks          Json?            @map("social_links") // {instagram, facebook, tiktok, website, snapchat, youtube}
  profileViews         Int              @default(0) @map("profile_views")
  pointsRules          Json?            @map("points_rules")
  pointsRate           Float            @default(10) @map("points_rate")
  loyaltyType          LoyaltyType      @default(POINTS) @map("loyalty_type")
  conversionRate       Float            @default(10) @map("conversion_rate")
  stampsForReward      Int              @default(10) @map("stamps_for_reward")
  stampEarningMode     StampEarningMode @default(PER_VISIT) @map("stamp_earning_mode")
  accumulationLimit    Int?             @map("accumulation_limit")
  activeRewardId       String?          @map("active_reward_id")
  // Plan Freemium — les nouveaux marchands démarrent en FREE (le flow d'inscription attribue un essai PREMIUM via getTrialData())
  plan                 MerchantPlan     @default(FREE)
  planExpiresAt        DateTime?        @map("plan_expires_at")
  planActivatedByAdmin Boolean          @default(false) @map("plan_activated_by_admin")
  trialStartedAt       DateTime?        @map("trial_started_at")

  isActive            Boolean   @default(true) @map("is_active")
  emailVerified       Boolean   @default(false) @map("email_verified")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // ── Programme de parrainage ──
  referralCode          String?    @unique @map("referral_code")
  referredById          String?    @map("referred_by_id")
  referredBy            Merchant?  @relation("MerchantReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals             Merchant[] @relation("MerchantReferrals")
  referralMonthsEarned  Int        @default(0) @map("referral_months_earned")
  referralBonusCredited Boolean    @default(false) @map("referral_bonus_credited")

  loyaltyCards    LoyaltyCard[]
  transactions    Transaction[]
  rewards         Reward[]
  notifications   Notification[]
  teamMembers     TeamMember[]
  deviceSessions  DeviceSession[]
  stores          Store[]
  profileViewsLog ProfileView[]
  clientReferral  ClientReferral[]

  // ── Parrainage par client ──
  referredByClientId String? @map("referred_by_client_id")
  referredByClient   Client? @relation("ClientMerchantReferrals", fields: [referredByClientId], references: [id], onDelete: SetNull)

  // Champs pour le quota WhatsApp
  whatsappQuotaUsed    Int      @default(0)
  whatsappQuotaMax     Int      @default(100)
  whatsappQuotaResetAt DateTime @default(now())

  // Champs pour le quota Email
  emailQuotaUsed    Int      @default(0)
  emailQuotaMax     Int      @default(200)
  emailQuotaResetAt DateTime @default(now())

  // Admin notifications
  lastAdminNotifReadAt DateTime?                  @map("last_admin_notif_read_at")
  notificationReads    MerchantNotificationRead[]

  @@index([isActive])
  @@index([deletedAt])
  // Discovery queries filter by category + city — composite index avoids full table scans
  @@index([categorie, ville, isActive])
  // Geospatial proximity queries (nearby merchants)
  @@index([latitude, longitude])
  // Admin dashboard: count by plan, filter active+plan
  @@index([plan])
  @@index([isActive, plan])
  // Admin list filtering: plan + active + date sort
  @@index([plan, isActive, createdAt(sort: Desc)])
  @@index([appleId])
  @@map("merchants")
}

model Store {
  id          String            @id @default(uuid())
  merchantId  String            @map("merchant_id")
  nom         String            @db.VarChar(255)
  description String?           @db.VarChar(1000)
  categorie   MerchantCategory?
  ville       String?           @db.VarChar(100)
  quartier    String?           @db.VarChar(100)
  adresse     String?           @db.VarChar(500)
  latitude    Float?
  longitude   Float?
  telephone   String?           @db.VarChar(20)
  email       String?           @db.VarChar(255)
  logoUrl     String?           @map("logo_url")
  coverUrl    String?           @map("cover_url")
  socialLinks Json?             @map("social_links")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  // Active store lookups by merchant (discovery + nearby)
  @@index([merchantId, isActive])
  // Geospatial store queries for nearby search
  @@index([isActive, latitude, longitude])
  @@map("stores")
}

model Admin {
  id                  String    @id @default(uuid())
  email               String    @unique @db.VarChar(255)
  password            String    @db.VarChar(255)
  nom                 String    @db.VarChar(255)
  role                AdminRole @default(ADMIN)
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("admins")
}

enum MerchantCategory {
  CAFE
  RESTAURANT
  EPICERIE
  BOULANGERIE
  PHARMACIE
  LIBRAIRIE
  VETEMENTS
  ELECTRONIQUE
  COIFFURE
  BEAUTE
  SPORT
  SUPERMARCHE
  AUTRE
}

enum AdminRole {
  ADMIN
}

// ── Audit log action catalogue ────────────────────────────────
enum AuditAction {
  // Auth
  ADMIN_LOGIN
  // Plan management
  ACTIVATE_PREMIUM
  REVOKE_PREMIUM
  // Merchant lifecycle
  BAN_MERCHANT
  UNBAN_MERCHANT
  DELETE_MERCHANT
  // Client lifecycle
  DEACTIVATE_CLIENT
  ACTIVATE_CLIENT
  DELETE_CLIENT
  // Admin notifications
  ADMIN_SEND_NOTIFICATION
  // Future-proof slots
  RESET_PASSWORD
  UPDATE_PLAN_DURATION
  UPDATE_PAYOUT
}

enum AuditTargetType {
  MERCHANT
  CLIENT
  ADMIN
}

// ── Audit log table ───────────────────────────────────────────
model AuditLog {
  id          String          @id @default(uuid())
  /// Admin who performed the action
  adminId     String          @map("admin_id")
  admin       Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminEmail  String          @map("admin_email")
  action      AuditAction
  /// Type of resource affected: "MERCHANT", "CLIENT", "ADMIN"
  targetType  AuditTargetType @map("target_type")
  /// PK of the affected resource (nullable for login events)
  targetId    String?         @map("target_id")
  /// Human-readable label (e.g. merchant name + email) for quick read
  targetLabel String?         @map("target_label")
  /// Extra context as JSON (old plan, new plan, reason, …)
  metadata    Json?
  /// Client IP address of the admin
  ipAddress   String?         @map("ip_address")
  userAgent   String?         @map("user_agent")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@index([adminId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum MerchantPlan {
  FREE
  PREMIUM
}

enum LoyaltyType {
  POINTS
  STAMPS
}

enum StampEarningMode {
  PER_VISIT
  PER_AMOUNT
}

model Client {
  id                  String    @id @default(uuid())
  prenom              String?   @db.VarChar(255)
  nom                 String?   @db.VarChar(255)
  email               String?   @unique @db.VarChar(255)
  emailVerified       Boolean   @default(false) @map("email_verified")
  password            String?   @db.VarChar(255)
  telephone           String?   @unique @db.VarChar(20)
  telephoneVerified   Boolean   @default(false) @map("telephone_verified")
  googleId            String?   @unique @map("google_id") @db.VarChar(255)
  appleId             String?   @unique @map("apple_id") @db.VarChar(255)
  countryCode         String    @default("MA") @map("country_code") @db.VarChar(5)
  pushToken           String?   @map("push_token") @db.VarChar(512)
  refreshTokenHash    String?   @unique @map("refresh_token_hash")
  termsAccepted       Boolean   @default(false) @map("terms_accepted")
  shareInfoMerchants  Boolean   @default(false) @map("share_info_merchants")
  notifPush           Boolean   @default(true) @map("notif_push")
  notifEmail          Boolean   @default(true) @map("notif_email")
  notifWhatsapp       Boolean   @default(true) @map("notif_whatsapp")
  dateNaissance       DateTime? @map("date_naissance")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // ── Programme de parrainage client ──
  referralCode    String? @unique @map("referral_code")
  referralBalance Float   @default(0) @map("referral_balance")

  loyaltyCards         LoyaltyCard[]
  transactions         Transaction[]
  notificationStatuses ClientNotificationStatus[]
  profileViewsLog      ProfileView[]
  clientReferrals      ClientReferral[]
  referredMerchants    Merchant[]                 @relation("ClientMerchantReferrals")
  payoutRequests       PayoutRequest[]

  @@index([nom])
  @@index([email])
  @@index([telephone])
  @@index([deletedAt, createdAt])
  @@index([countryCode])
  // refreshTokenHash is @unique — implicit index
  // Notification broadcast: filters on pushToken IS NOT NULL + notifPush = true
  @@index([notifPush])
  // Broadcast-optimised: covers WHERE notifPush=true AND deletedAt IS NULL AND pushToken IS NOT NULL
  @@index([notifPush, deletedAt, pushToken])
  @@index([googleId])
  @@index([appleId])
  @@map("clients")
}

model Otp {
  id        String   @id @default(uuid())
  telephone String?  @unique
  email     String?  @unique
  code      String
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt, createdAt(sort: Desc)])
  @@map("otps")
}

model LoyaltyCard {
  id            String    @id @default(uuid())
  clientId      String    @map("client_id")
  merchantId    String    @map("merchant_id")
  points        Int       @default(0)
  deactivatedAt DateTime? @map("deactivated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@unique([clientId, merchantId])
  @@index([merchantId])
  @@index([clientId])
  @@index([merchantId, createdAt])
  // Accumulation cap queries: fetch cards over limit for a merchant
  @@index([merchantId, points])
  // Broadcast notification: cursor-paginated lookup of active cards per merchant
  @@index([merchantId, deactivatedAt, clientId])
  @@map("loyalty_cards")
}

model Transaction {
  id              String            @id @default(uuid())
  clientId        String            @map("client_id")
  merchantId      String            @map("merchant_id")
  rewardId        String?           @map("reward_id")
  teamMemberId    String?           @map("team_member_id")
  performedByName String?           @map("performed_by_name")
  type            TransactionType
  loyaltyType     LoyaltyType?      @map("loyalty_type")
  note            String?
  amount          Float             @default(0)
  points          Int
  status          TransactionStatus @default(ACTIVE)
  giftStatus      GiftStatus?       @map("gift_status")
  fulfilledAt     DateTime?         @map("fulfilled_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  merchant   Merchant    @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  reward     Reward?     @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  teamMember TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)

  @@index([merchantId, status, createdAt])
  @@index([clientId, status, createdAt])
  @@index([clientId, merchantId])
  @@index([merchantId, type, status, createdAt])
  @@index([rewardId])
  // Admin dashboard: count by type, filter status+date
  @@index([type])
  @@index([status, createdAt(sort: Desc)])
  // Pending gifts lookup: quickly find PENDING gifts for a merchant
  @@index([merchantId, giftStatus, createdAt])
  // Dashboard + transaction history: merchant sorted by date
  @@index([merchantId, createdAt(sort: Desc)])
  @@map("transactions")
}

enum TransactionType {
  EARN_POINTS
  REDEEM_REWARD
  ADJUST_POINTS
  LOYALTY_PROGRAM_CHANGE
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
}

enum GiftStatus {
  PENDING
  FULFILLED
}

enum TeamRole {
  TEAM_MEMBER
}

model TeamMember {
  id                  String    @id @default(uuid())
  merchantId          String    @map("merchant_id")
  nom                 String    @db.VarChar(255)
  email               String    @unique @db.VarChar(255)
  password            String    @db.VarChar(255)
  role                TeamRole  @default(TEAM_MEMBER)
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([merchantId])
  @@map("team_members")
}

model Reward {
  id          String   @id @default(uuid())
  merchantId  String   @map("merchant_id")
  titre       String   @db.VarChar(255)
  cout        Int
  description String?  @db.VarChar(1000)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([merchantId])
  @@map("rewards")
}

/// Channel used for a notification blast (stored as TEXT in DB).
/// Values: 'PUSH', 'EMAIL', 'WHATSAPP'

model Notification {
  id             String   @id @default(uuid())
  merchantId     String?  @map("merchant_id")
  title          String   @db.VarChar(255)
  body           String   @db.VarChar(2000)
  recipientCount Int      @default(0) @map("recipient_count")
  successCount   Int      @default(0) @map("success_count")
  failureCount   Int      @default(0) @map("failure_count")
  isBroadcast    Boolean  @default(false) @map("is_broadcast")
  channel        String?  @map("channel")
  audience       String?  @map("audience") @db.VarChar(30)
  createdAt      DateTime @default(now()) @map("created_at")

  merchant       Merchant?                  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  clientStatuses ClientNotificationStatus[]
  merchantReads  MerchantNotificationRead[]

  @@index([channel, createdAt(sort: Desc)])
  // Admin stats: groupBy channel filtered by audience
  @@index([channel, audience, createdAt(sort: Desc)])
  // Merchant history + client notification list: merchantId + createdAt DESC
  @@index([merchantId, createdAt(sort: Desc)])
  @@index([audience, createdAt(sort: Desc)])
  @@map("notifications")
}

/// Per-merchant notification read status for admin broadcast notifications.
model MerchantNotificationRead {
  merchantId     String   @map("merchant_id")
  notificationId String   @map("notification_id")
  readAt         DateTime @default(now()) @map("read_at")

  merchant     Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@id([merchantId, notificationId])
  @@index([notificationId])
  @@map("merchant_notification_reads")
}

/// Per-client notification status: tracks read/dismissed state.
model ClientNotificationStatus {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  notificationId String    @map("notification_id")
  isRead         Boolean   @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  isDismissed    Boolean   @default(false) @map("is_dismissed")
  dismissedAt    DateTime? @map("dismissed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([clientId, notificationId])
  @@index([clientId, isDismissed])
  @@index([clientId, isRead])
  @@index([notificationId])
  @@map("client_notification_statuses")
}

model DeviceSession {
  id              String   @id @default(uuid())
  merchantId      String   @map("merchant_id")
  tokenId         String?  @unique @map("token_id")
  deviceId        String?  @map("device_id")
  deviceName      String   @map("device_name")
  deviceOS        String?  @map("device_os")
  userType        String?  @map("user_type")
  userEmail       String?  @map("user_email")
  userName        String?  @map("user_name")
  lastActiveAt    DateTime @default(now()) @map("last_active_at")
  ipAddress       String?  @map("ip_address")
  isCurrentDevice Boolean  @default(false) @map("is_current_device")
  createdAt       DateTime @default(now()) @map("created_at")

  refreshTokenHash String? @map("refresh_token_hash")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([merchantId, deviceId])
  @@index([merchantId, deviceName])
  @@map("device_sessions")
}

// ── Profile view tracking (one view per client per merchant per day) ──
model ProfileView {
  id         String   @id @default(uuid())
  merchantId String   @map("merchant_id")
  clientId   String   @map("client_id")
  viewDate   DateTime @map("view_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([merchantId, clientId, viewDate])
  @@index([merchantId, viewDate])
  @@index([clientId])
  @@map("profile_views_log")
}

// ── Parrainage client → commerce ─────────────────────────────────────────────
enum ClientReferralStatus {
  PENDING
  VALIDATED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum PayoutMethod {
  BANK_TRANSFER
  CASH
}

model ClientReferral {
  id          String               @id @default(uuid())
  clientId    String               @map("client_id")
  merchantId  String               @unique @map("merchant_id")
  status      ClientReferralStatus @default(PENDING)
  amount      Float                @default(0)
  validatedAt DateTime?            @map("validated_at")
  createdAt   DateTime             @default(now()) @map("created_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("client_referrals")
}

model PayoutRequest {
  id              String       @id @default(uuid())
  clientId        String       @map("client_id")
  amount          Float
  status          PayoutStatus @default(PENDING)
  method          PayoutMethod
  accountDetails  Json?         @map("account_details")
  rejectionReason String?      @map("rejection_reason")
  approvedAt      DateTime?    @map("approved_at")
  rejectedAt      DateTime?    @map("rejected_at")
  paidAt          DateTime?    @map("paid_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@map("payout_requests")
}
