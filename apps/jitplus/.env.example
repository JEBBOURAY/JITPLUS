# ── JitPlus Client App Environment Variables ──
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Backend API URL (use HTTP for local dev, HTTPS for staging/production)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Maps API key (restricted to Android/iOS package names in Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth Client IDs (from Google Cloud Console → Credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Sentry DSN for crash reporting (from sentry.io → Project Settings → Client Keys)
EXPO_PUBLIC_SENTRY_DSN=
