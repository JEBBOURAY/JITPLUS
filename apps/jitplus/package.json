{
  "name": "jitplus",
  "main": "expo-router/entry",
  "version": "1.3.4",
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native",
        "expo-image"
      ]
    }
  },
  "scripts": {
    "eas-build-pre-install": "corepack enable",
    "start": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.116 expo start --host lan --port 8083 --go --clear",
    "start:go": "cross-env EXPO_NO_DOCTOR=1 REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.116 expo start --host lan --port 8083 --go --clear",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@expo-google-fonts/lexend": "^0.4.1",
    "@jitplus/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@sentry/react-native": "^8.4.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^7.0.10",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image": "^55.0.6",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^15.0.10",
    "i18n-js": "^4.5.3",
    "lucide-react-native": "^0.564.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "socket.io-client": "^4.8.3",
    "supercluster": "^8.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.17",
    "@types/supercluster": "^7.1.3",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "private": true
}
