# ╔══════════════════════════════════════════════════════════════════════╗
# ║  JitPlus — Variables de production pour GCP                           ║
# ║  • Ces valeurs sont injectées via Secret Manager → Cloud Run         ║
# ║  • Copier dans .env.production pour usage docker-compose local       ║
# ║  • Sur GCP utiliser : gcloud run services update --set-env-vars       ║
# ║    ou monter les secrets via --set-secrets                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Node / Serveur ───────────────────────────────────────────────
# Cloud Run set PORT=8080 automatiquement. Laisser tel quel.
NODE_ENV=production
PORT=8080
BACKEND_URL=https://YOUR-CLOUD-RUN-URL.run.app

# ── CORS (origines autorisées) ─────────────────────────────────
# Remplacer par le(s) domaine(s) réel(s) de vos apps Expo/web.
CORS_ORIGINS=https://jitplus.com,https://pro.jitplus.com

# ── Base de données — Cloud SQL (PostgreSQL) ─────────────────────
# Sur Cloud Run, la connexion se fait via unix socket (pas TCP).
# Format : postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
#
# Exemple :
#   DATABASE_URL=postgresql://jitplus:VOTRE_MOT_DE_PASSE@/jitplus_db?host=/cloudsql/jitplus-97259:europe-west1:jitplus-pg
#
# En local avec docker-compose, utiliser le format TCP standard :
#   DATABASE_URL=postgresql://admin:password@postgres:5432/jit_db?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Nom de l'instance Cloud SQL (PROJECT:REGION:INSTANCE)
# Utilisé par Cloud Run pour autoriser la connexion Cloud SQL Proxy
CLOUD_SQL_INSTANCE=jitplus-97259:europe-west1:jitplus-pg

# ── Redis — Cloud Memorystore ────────────────────────────────
# Cloud Memorystore est accessible via VPC Connector (pas d'authent par défaut).
# Format : redis://IP_MEMORYSTORE:6379
# Si AUTH activé : redis://:PASSWORD@IP_MEMORYSTORE:6379
REDIS_URL=redis://10.0.0.X:6379

# ── JWT ──────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64
JWT_EXPIRATION=7d

# Separate HMAC key for QR tokens (recommended — falls back to JWT_SECRET if empty)
# Générer avec : openssl rand -base64 32
QR_HMAC_SECRET=CHANGE_ME_openssl_rand_base64_32

# ── Sentry — Error Monitoring ────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0

# ── Google Cloud Storage ──────────────────────────────────
# Sur Cloud Run, l'auth GCS est automatique via le compte de service attaché.
# Aucune clé JSON (GOOGLE_APPLICATION_CREDENTIALS) n'est nécessaire.
GCP_PROJECT_ID=jitplus-97259
GCP_STORAGE_BUCKET_NAME=jitplus-uploads-prod

# ── Firebase Admin SDK (Push Notifications) ───────────────────
# Créer une clé de compte de service dans Firebase Console.
# FIREBASE_PRIVATE_KEY : copier la valeur du champ "private_key" (avec les \n)
FIREBASE_PROJECT_ID=jitplus-97259
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXX@jitplus-97259.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Google OAuth (connexion client Google) ────────────────────
GOOGLE_CLIENT_ID=XXXXXXXXXXXX-XXXX.apps.googleusercontent.com

# ── Twilio (OTP SMS) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_OTP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MARKETING_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (Email OTP + blasts) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP (emails transactionnels via nodemailer) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@jitplus.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=JitPlus <contact@jitplus.com>
