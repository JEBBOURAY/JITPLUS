# Required for React Native + Expo in pnpm monorepo
# Hoists these packages to root node_modules so Gradle's node scripts
# (e.g. react-native-reanimated's build.gradle) can resolve them via
# standard Node module resolution.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*@react-navigation*
public-hoist-pattern[]=*@babel*
